# ---- Postgres ----
POSTGRES_USER=querion
POSTGRES_PASSWORD=querion_secret
POSTGRES_DB=querion
DATABASE_URL=postgresql+asyncpg://querion:querion_secret@localhost:5432/querion

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- MinIO ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=querion-docs
MINIO_USE_SSL=false

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Auth / JWT ----
JWT_SECRET=querion-dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Super Admin Seed ----
SUPER_ADMIN_EMAIL=admin@querion.io
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_NAME=Super Admin

# ---- Encryption (Fernet key for API key encryption in DB) ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
